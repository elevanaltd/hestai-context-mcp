# OS
.DS_Store
Thumbs.db

# Git worktrees (HestAI Workbench)
/worktrees/
/worktree-*/

# HestAI Three-Tier Architecture
# Tier 1: System governance (MCP-delivered, never committed)
.hestai-sys/
# Tier 3: Working state (gitignored, symlinked from .hestai/state/)
.hestai-state/
.hestai/state

# Raw debate transcripts (OCTAVE compressed versions are committed)
debates/*.json
debates/*.jsonl
debates/*.lock

# Claude Code local settings (user-specific)
/.claude/settings.json
/.claude/settings.local.json
/.claude/commands/

# Gemini clipboard cache
.gemini-clipboard/
